PORT=3001
NODE_ENV=development

# Supabase — copy the full URI from Dashboard (see README for pooler choice)
#
# Session pooler (recommended for this Express API) — port 5432:
# DATABASE_URL=postgresql://postgres.yddxbmqisbknhrzfccon:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:5432/postgres
#
# Transaction pooler (serverless only) — port 6543:
DATABASE_URL=postgresql://postgres.yddxbmqisbknhrzfccon:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres

USE_MEMORY_STORE=false
CORS_ORIGIN=http://localhost:5173

OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.5-397b-a17b
OPENROUTER_MODEL_DEV=minimax/minimax-m2.5
OPENROUTER_PROVIDER_IGNORE=Novita
USE_PRODUCTION_MODEL=false
AGENT_MAX_TOOL_ITERATIONS=5
# EXA_API_KEY=
